{
  "name": "electron-ipc-bridge-monorepo",
  "private": true,
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^10.0.0"
  },
  "scripts": {
    "test": "pnpm -r test",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deps:check": "pnpm exec syncpack lint --config .syncpackrc.json --dependency-types \"dev,prod\"",
    "deps:fix": "pnpm exec syncpack fix --config .syncpackrc.json --dependency-types \"dev,prod\"",
    "deps:update": "pnpm exec syncpack update --config .syncpackrc.json --dependency-types \"dev,prod\" --target latest && pnpm run deps:fix && pnpm install",
    "deps:check:peers": "node scripts/check-peer-ranges.mjs"
  },
  "packageManager": "pnpm@10.25.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "electron": "^41.4.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.2",
    "syncpack": "^14.3.1",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
